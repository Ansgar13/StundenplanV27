<Window x:Class="Stundenplan_V2.KlasseFixierenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unterricht fixieren"
        Height="520"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Klassen -->
        <TextBlock Grid.Row="0"
                   Text="Klassen (Mehrfachauswahl möglich):"
                   Margin="0,0,0,4"/>
        <ListBox x:Name="LstKlassen"
                 Grid.Row="1"
                 SelectionMode="Multiple"
                 Margin="0,0,0,12"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Fächer -->
        <TextBlock Grid.Row="2"
                   Text="Fächer (Mehrfachauswahl möglich):"
                   Margin="0,0,0,4"/>
        <ListBox x:Name="LstFächer"
                 Grid.Row="3"
                 SelectionMode="Multiple"
                 Margin="0,0,0,12"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Hinweis -->
        <TextBlock Grid.Row="4"
                   Text="Mindestens eine Klasse oder ein Fach auswählen."
                   FontSize="11"
                   Foreground="Gray"
                   Margin="0,0,0,10"/>

        <!-- Lösung -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    Margin="0,0,0,16" VerticalAlignment="Center">
            <TextBlock Text="Lösung:" VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <ComboBox x:Name="CmbLösung" Width="300"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="80"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="BtnOk_Click"/>
            <Button Content="Abbrechen"
                    Width="80"
                    IsCancel="True"
                    Click="BtnAbbrechen_Click"/>
        </StackPanel>
    </Grid>
</Window>
